{
  "version": "1.0.0",
  "description": "Firmware Download Tool Configuration",
  "settings": {
    "defaultPort": "auto",
    "timeout": 300,
    "retryCount": 3
  },
  "serial": {
    "baudrate": 115200,
    "dataBits": 8,
    "parity": "none",
    "stopBits": 1
  },
  "outputConfig": {
    "progressMode": "single-line",
    "verbose": false,
    "timestamp": false
  }
}
