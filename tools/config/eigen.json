{
  "platform": {
    "type": "ecf",
    "extensions": ["_download_usb.ini"],
    "description": "Eigen 618/718",
    "serial": {
      "atPortPatterns": ["at port", "at usb"],
      "atCommand": "AT+QDOWNLOAD=1",
      "baudrate": 115200,
      "autoEnterDlMode": true,
      "downloadPortPatterns": ["download"],
      "downloadPortVidPid": [
        { "vid": "17d1", "pid": "0001", "desc": "BOOT" }
      ]
    },
    "progressPatterns": {
      "started": ["init", "start", "begin"],
      "downloading": ["download", "burning", "flashing"],
      "completed": ["complete", "success", "finished"],
      "error": ["error", "fail", "timeout"]
    }
  },
  "tool": {
    "name": "ECFlashTool",
    "path": "ecflashtool/ECFlashTool.exe",
    "description": "Eigen Download Tool",
    "args": {
      "flash": ["-f", "{firmwarePath}", "--timeout", "60"],
      "default": []
    }
  }
}
