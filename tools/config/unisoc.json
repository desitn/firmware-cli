{
  "platform": {
    "type": "pac",
    "extensions": [".pac"],
    "description": "UNISOC 8310/8910/8850",
    "serial": {
      "atPortPatterns": ["at port", "modem"],
      "atCommand": "AT+QDOWNLOAD=1",
      "atCommandForce": "AT+QDOWNLOAD=2",
      "baudrate": 115200,
      "autoEnterDlMode": true,
      "downloadPortPatterns": ["SPRD U2S Diag"],
      "downloadPortVidPid": [
        { "vid": "1782", "pid": "4d00", "desc": "BOOT" }
      ]
    },
    "progressPatterns": {
      "started": ["init", "start", "begin"],
      "downloading": ["download", "burning", "flashing"],
      "completed": ["complete", "success", "finished"],
      "error": ["error", "fail", "timeout"]
    }
  },
  "tool": {
    "name": "CmdDloader",
    "path": "pacdownload/CmdDloader.exe",
    "description": "UNISOC Download Tool",
    "args": {
      "flash": ["-pac", "{firmwarePath}"],
      "default": []
    }
  }
}
