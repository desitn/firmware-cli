{
  "name": "dove",
  "version": "1.0.2",
  "description": "Release a dove, deliver your firmware",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "ts-node src/index.ts help",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:exe": "npm run build && pkg . --targets node18-win-x64 --output ./dove.exe",
    "dev": "ts-node src/index.ts",
    "clean": "rimraf dist",
    "skill-validate": "node tools/skill-validate.js"
  },
  "author": "destin.zhang@quectel.com",
  "license": "MIT",
  "dependencies": {
    "@serialport/parser-readline": "^12.0.0",
    "adm-zip": "^0.5.10",
    "iconv-lite": "^0.6.3",
    "serialport": "^12.0.0"
  },
  "bin": {
    "dove": "./dist/index.js"
  },
  "pkg": {
    "scripts": [
      "dist/*.js"
    ],
    "assets": [
      "node_modules/@serialport/bindings-cpp/prebuilds/win32-x64/*.node"
    ]
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "pkg": "^5.8.1",
    "react": "^18.3.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ]
}
